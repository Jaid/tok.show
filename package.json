{
  "name": "tok.show",
  "displayName": "Tok·Show",
  "version": "0.1.0",
  "type": "module",
  "description": "web app for offline LLM tokenization supporting a wide range of popular models",
  "imports": {
    "#src/*": "./src/*",
    "#root/*": "./*",
    "#component/*": "./src/components/*/index.tsx"
  },
  "scripts": {
    "build": "bun run vite build --mode development",
    "build:production": "bun run vite build --mode production",
    "lint": "tsc --noEmit --noUnusedLocals --pretty false ; knip-bun --reporter json",
    "test-live": "bun run build:production && target=dist bun test test/live.test.ts",
    "vite": "bun node_modules/vite/dist/node/cli.js --configLoader runner"
  },
  "dependencies": {
    "@dnd-kit/react": "0.4.0",
    "@floating-ui/react": "0.27.19",
    "@monaco-editor/react": "4.8.0-rc.3",
    "clsx": "2.1.1",
    "es-toolkit": "1.47.0",
    "monaco-editor": "0.55.1",
    "nuqs": "2.8.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hotkeys-hook": "5.3.2",
    "react-icons": "5.6.0",
    "react-resizable-panels": "4.11.2",
    "token-vocabs": "0.5.0",
    "valtio": "2.1.6"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@rolldown/plugin-babel": "0.2.3",
    "@types/postcss-normalize": "9.0.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "autoprefixer": "10.5.0",
    "babel-plugin-react-compiler": "1.0.0",
    "browserslist": "4.28.2",
    "bun-types": "1.3.14",
    "caniuse-lite": "1.0.30001797",
    "count-in-png": "0.1.0",
    "cssnano-preset-advanced": "8.0.1",
    "eslint": "10.4.1",
    "fs-extra": "11.3.5",
    "knip": "6.16.0",
    "optis": "0.1.0",
    "postcss-normalize": "13.0.1",
    "puppeteer-core": "25.1.0",
    "sass-embedded": "1.100.0",
    "terser": "5.48.0",
    "tsconfig-jaid-react": "15.2.0",
    "type-fest": "5.7.0",
    "vite": "8.0.16",
    "vite-plugin-media-mixins": "0.4.0",
    "vite-plugin-title": "0.5.0"
  }
}
